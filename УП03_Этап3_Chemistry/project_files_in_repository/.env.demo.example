# Пример переменных для локального demo-стенда (УП.03 этап 3).
# Скопируйте: copy .env.demo.example .env.demo
# Не коммитьте .env.demo с реальными паролями.

COMPOSE_PROJECT_NAME=chemistry-demo
APP_ENVIRONMENT=demo
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=5000

ASPNETCORE_ENVIRONMENT=Development
Swagger__Enabled=true
Database__ApplyMigrationsOnStartup=true
Security__EnableRateLimiting=false

FRONTEND_PORT=3000
API_PORT=5000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

POSTGRES_DB=chemistry_db
POSTGRES_USER=chemistry_user
POSTGRES_PASSWORD=change_me_demo_db

REDIS_PASSWORD=change_me_demo_redis
REDIS_MAXMEMORY=256mb

MINIO_ROOT_USER=change_me_demo_minio
MINIO_ROOT_PASSWORD=change_me_demo_minio_secret
MINIO_BUCKET_PHOTOS=photos
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_DOCUMENTS=documents

JWT_SECRET=change_me_to_a_32_byte_minimum_random_secret
DATA_PROTECTION_KEY=change_me_base64_32_bytes_key_for_demo==

VITE_APP_TITLE=Chemistry Na Easy
VITE_ENABLE_ANALYTICS=false
VITE_FEATURE_CAPTCHA=false
VITE_FEATURE_OAUTH=false
VITE_FEATURE_PAYMENT_SANDBOX=true
VITE_PAYMENT_PROVIDER=Mock

Payments__Provider=Mock
Payments__Sandbox=true
Payments__RequireWebhookSignature=false

Captcha__Enabled=false
Shipping__Provider=Mock
Shipping__Sandbox=true
Notifications__Email__Provider=Mock

LOG_LEVEL=Information
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
