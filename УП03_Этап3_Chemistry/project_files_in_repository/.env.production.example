# Пример production-переменных для VPS/deploy (без реальных секретов).
# Скопируйте: copy .env.production.example .env.production
# На сервере значения задаются через GitHub Secrets / generated.env (см. deploy/RUNBOOK.md).

APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=5000

ASPNETCORE_ENVIRONMENT=Production
Swagger__Enabled=false
Database__ApplyMigrationsOnStartup=false
Security__EnableRateLimiting=true

FRONTEND_PORT=3000
API_PORT=5000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GRAFANA_PORT=3001
LOKI_PORT=3100

POSTGRES_DB=chemistry_db
POSTGRES_USER=chemistry_user
POSTGRES_PASSWORD=change_me

REDIS_PASSWORD=change_me
REDIS_MAXMEMORY=256mb

MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me

JWT_SECRET=change_me_in_real_environment
DATA_PROTECTION_KEY=change_me_base64_32_bytes

ALLOWED_HOSTS=localhost,127.0.0.1,example.com
CORS_ORIGINS=https://example.com

LOG_LEVEL=INFO

DOMAIN_FRONTEND=example.com
DOMAIN_API=api.example.com
LETSENCRYPT_EMAIL=admin@example.com

FRONTEND_IMAGE=ghcr.io/studio-kairos/chemistry-frontend:latest
BACKEND_IMAGE=ghcr.io/studio-kairos/chemistry-backend:latest

Payments__Provider=OzonPay
Payments__Sandbox=false
Payments__RequireWebhookSignature=true

Captcha__Enabled=true
Shipping__Provider=RussianPost
Shipping__Sandbox=false
Analytics__Enabled=true
Privacy__RequireConsent=true
