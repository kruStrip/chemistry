# Сводный шаблон Chemistry — скопируйте в подпроекты:
#   chemistry-backend\deploy\.env  ← из chemistry-backend\deploy\.env.example
#   chemistry-frontend\.env        ← из chemistry-frontend\.env.example
#
# Быстрый старт: scripts\setup.bat

COMPOSE_PROJECT_NAME=chemistry
API_PORT=5000
FRONTEND_PORT=3000
POSTGRES_DB=chemistry_db
POSTGRES_USER=chemistry_user
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me
JWT_SECRET=change_me_to_a_32_byte_minimum_random_secret

VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:3000
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
VITE_APP_TITLE=Chemistry Na Easy
VITE_ENABLE_ANALYTICS=false
