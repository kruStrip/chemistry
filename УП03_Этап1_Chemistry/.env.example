# Сводный шаблон настроек проекта Chemistry (без секретов)
# Полные шаблоны: chemistry-backend/deploy/.env.example (228 переменных)
#                  chemistry-frontend/.env.example

# === FRONTEND (chemistry-frontend/.env) ===
VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:3000
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
VITE_APP_TITLE=Chemistry Na Easy
VITE_ENABLE_ANALYTICS=false
VITE_FEATURE_CAPTCHA=false
VITE_FEATURE_OAUTH=false
VITE_FEATURE_PAYMENT_SANDBOX=true
VITE_PAYMENT_PROVIDER=OzonPay
VITE_MEDIA_BASE_URL=https://s3.example.com

# === BACKEND (chemistry-backend/deploy/.env) — минимум для запуска ===
COMPOSE_PROJECT_NAME=chemistry
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000
FRONTEND_PORT=3000
POSTGRES_DB=chemistry_db
POSTGRES_USER=chemistry_user
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me
JWT_SECRET=change_me_to_a_32_byte_minimum_random_secret
DATA_PROTECTION_KEY=
GRAFANA_ADMIN_PASSWORD=change_me
Database__ApplyMigrationsOnStartup=true
Swagger__Enabled=true
